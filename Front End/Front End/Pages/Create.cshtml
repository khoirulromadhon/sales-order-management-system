@page
@model Front_End.Pages.CreateModel
@{
    ViewData["Title"] = "Create / Edit Sales Order";
}

<div class="container">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="fw-bold">@(
                Model.View ? "View Sales Order" : (Model.IsEdit ? "Edit Sales Order" : "Create Sales Order")
            )</h3>
        </div>
    </div>

    <form method="post" class="row g-3">
        <input type="hidden" asp-for="SalesOrder.Id" />

        <div class="col-md-4">
            <label asp-for="SalesOrder.SoNumber" class="form-label">SO Number</label>
            @if (Model.View)
            {
                <input asp-for="SalesOrder.SoNumber" class="form-control" disabled />
            }
            else
            {
                <input asp-for="SalesOrder.SoNumber" class="form-control" />
            }
        </div>
        <div class="col-md-4">
            <label asp-for="SalesOrder.OrderDate" class="form-label">Order Date</label>
            @if (Model.View)
            {
                <input asp-for="SalesOrder.OrderDate" type="date" class="form-control" disabled />
            }
            else
            {
                <input asp-for="SalesOrder.OrderDate" type="date" class="form-control" />
            }
        </div>
        <div class="col-md-4">
            <label asp-for="SalesOrder.CustomerName" class="form-label">Customer</label>
            @if (Model.View)
            {
                <input asp-for="SalesOrder.CustomerName" class="form-control" disabled />
            }
            else
            {
                <input asp-for="SalesOrder.CustomerName" class="form-control" />
            }
        </div>
        <div class="col-12">
            <label asp-for="SalesOrder.Address" class="form-label">Address</label>
            @if (Model.View)
            {
                <input asp-for="SalesOrder.Address" class="form-control" disabled />
            }
            else
            {
                <input asp-for="SalesOrder.Address" class="form-control" />
            }
        </div>

        <div class="col-12">
            <h5>Details</h5>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th style="width:120px">Qty</th>
                        <th style="width:150px">Unit Price</th>
                        <th style="width:60px"></th>
                    </tr>
                </thead>
                <tbody id="details-body">
                    @for (int i = 0; i < Model.SalesOrder.Details.Count; i++)
                    {
                        <tr>
                            <td>
                                @if (Model.View)
                                {
                                    <input name="SalesOrder.Details[@i].ProductName" value="@Model.SalesOrder.Details[i].ProductName" class="form-control" disabled />
                                }
                                else
                                {
                                    <input name="SalesOrder.Details[@i].ProductName" value="@Model.SalesOrder.Details[i].ProductName" class="form-control" />
                                }
                            </td>
                            <td>
                                @if (Model.View)
                                {
                                    <input name="SalesOrder.Details[@i].Quantity" value="@Model.SalesOrder.Details[i].Quantity" type="number" class="form-control" disabled />
                                }
                                else
                                {
                                    <input name="SalesOrder.Details[@i].Quantity" value="@Model.SalesOrder.Details[i].Quantity" type="number" class="form-control" />
                                }
                            </td>
                            <td>
                                @if (Model.View)
                                {
                                    <input name="SalesOrder.Details[@i].UnitPrice" value="@Model.SalesOrder.Details[i].UnitPrice" type="number" step="0.01" class="form-control" disabled />
                                }
                                else
                                {
                                    <input name="SalesOrder.Details[@i].UnitPrice" value="@Model.SalesOrder.Details[i].UnitPrice" type="number" step="0.01" class="form-control" />
                                }
                            </td>
                            <td>
                                @if (!Model.View)
                                {
                                    <button type="button" class="btn btn-sm btn-danger" onclick="removeDetail(this)">Delete</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div>
                @if (!Model.View)
                {
                    <button type="button" class="btn btn-sm btn-success" onclick="addDetail()">Add Detail</button>
                }
            </div>
        </div>

        <div class="col-12 text-end">
            <a asp-page="/Index" class="btn btn-secondary me-2">Cancel</a>
            @if (!Model.View)
            {
                <button type="submit" class="btn btn-primary">Save</button>
            }
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function addDetail() {
            const tbody = document.getElementById('details-body');
            const index = tbody.rows.length;
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><input name="SalesOrder.Details[${index}].ProductName" class="form-control" /></td>
                <td><input name="SalesOrder.Details[${index}].Quantity" type="number" class="form-control" /></td>
                <td><input name="SalesOrder.Details[${index}].UnitPrice" type="number" step="0.01" class="form-control" /></td>
                <td><button type="button" class="btn btn-sm btn-danger" onclick="removeDetail(this)">-</button></td>
            `;
            tbody.appendChild(tr);
        }
        function removeDetail(btn) {
            const row = btn.closest('tr');
            row.remove();
            // re-index names
            const tbody = document.getElementById('details-body');
            for (let i = 0; i < tbody.rows.length; i++) {
                const inputs = tbody.rows[i].querySelectorAll('input');
                inputs[0].setAttribute('name', `SalesOrder.Details[${i}].ProductName`);
                inputs[1].setAttribute('name', `SalesOrder.Details[${i}].Quantity`);
                inputs[2].setAttribute('name', `SalesOrder.Details[${i}].UnitPrice`);
            }
        }
    </script>
}