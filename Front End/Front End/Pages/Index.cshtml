@page
@model IndexModel
@{
    ViewData["Title"] = "Sales Orders";
}

<div class="container">
    <!-- Top row: title left, buttons right -->
    <div class="row align-items-center mb-3">
        <div class="col">
            <h3 class="mb-0 fw-bold">Sales Order</h3>
        </div>
        <div class="col-auto">
            <button id="btnAddNew" type="button" class="btn btn-primary me-2">Add New</button>
            <button id="btnExport" type="button" class="btn btn-outline-secondary">Export</button>
        </div>
    </div>

    <!-- Search row: keyword, order date, search button -->
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-6">
            <input id="soKeyword" type="text" name="keyword" class="form-control" placeholder="Search keyword..."/>
        </div>
        <div class="col-md-3">
            <input id="soOrderDate" type="date" name="orderDate" class="form-control"/>
        </div>
        <div class="col-md-3">
            <input type="hidden" name="pageSize" value="5" />
            <button id="btnSearch" type="button" class="btn btn-primary w-100">Search</button>
        </div>
    </form>

    <!-- Table row -->
    <div class="row">
        <div class="col-12">
            <table class="table table-bordered table-hover">
                <thead class="table-light">
                    <tr>
                        <th style="width:40px">#</th>
                        <th>SO Number</th>
                        <th>Order Date</th>
                        <th>Customer</th>
                        <th>Address</th>
                        <th style="width:120px">Action</th>
                    </tr>
                </thead>
                <tbody id="salesOrderTBody">
                    <!-- Rows will be rendered by Index.js via AJAX -->
                </tbody>
            </table>
            <!-- Pagination controls handled by Index.js -->
            <div class="d-flex justify-content-center align-items-center mt-3">
                <button id="btnPrev" class="btn btn-sm btn-outline-secondary me-2">Previous</button>
                <span id="pageInfo">Page 1 of 1</span>
                <button id="btnNext" class="btn btn-sm btn-outline-secondary ms-2">Next</button>
            </div>
        </div>
    </div>

@section Scripts
{
    <script src="~/js/Index.js"></script>
}